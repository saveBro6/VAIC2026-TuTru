TZ=Asia/Ho_Chi_Minh
MONTE_CARLO_RUNS=300
STALE_AFTER_SECONDS=120
RETURN_REVIEW_SLA_MINUTES=30
NORMAL_RETURN_REVIEW_SLA_MINUTES=15
DATABASE_URL=sqlite:///./data/wait_time.db
AUTH_ENABLED=false
# JSON ánh xạ API key sang actor/scopes. Không dùng giá trị mẫu này trong production.
SERVICE_API_KEYS={"dev-read":{"actor_id":"local-reader","actor_type":"SERVICE","scopes":["wait.read"]},"dev-routing":{"actor_id":"routing-agent","actor_type":"SERVICE","scopes":["wait.read","events.write","simulation.run"]}}
MAX_CANDIDATE_ROOMS=20
MODEL_ARTIFACT_DIR=artifacts
MODEL_SCHEMA_VERSION=1
MONTE_CARLO_SERVICE_SIGMA=0.20
MONTE_CARLO_RESULT_SIGMA=0.30
MONTE_CARLO_EMERGENCY_PROBABILITY=0.02
MONTE_CARLO_EMERGENCY_MEAN_MINUTES=12
MONTE_CARLO_REVIEW_SIGMA=0.20
DEFAULT_EARLY_CHECKIN_WINDOW_MINUTES=20
MISSED_CALL_GRACE_MINUTES=5
MONTE_CARLO_ARRIVAL_SIGMA=0.20
MONTE_CARLO_OTHER_SERVICE_SIGMA=0.25
MONTE_CARLO_FUTURE_READY_PROBABILITY=0.90
WAITING_AREA_HIGH_OCCUPANCY=20
